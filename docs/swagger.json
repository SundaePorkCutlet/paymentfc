{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Payment, Xendit invoice, webhook, and audit for Go Commerce.",
        "title": "PAYMENTFC API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:28083",
    "basePath": "/",
    "paths": {
        "/api/v1/audit-logs": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "필터/커서 기반으로 결제 감사 로그를 조회합니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PAYMENT"
                ],
                "summary": "감사 로그 조회",
                "parameters": [
                    {
                        "type": "string",
                        "description": "이벤트명",
                        "name": "event",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "행위자",
                        "name": "actor",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "주문 ID",
                        "name": "order_id",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "사용자 ID",
                        "name": "user_id",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "커서(ObjectID)",
                        "name": "cursor",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "조회 개수",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "조회 시작 시각(RFC3339 또는 YYYY-MM-DD)",
                        "name": "from",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "조회 종료 시각(RFC3339 또는 YYYY-MM-DD)",
                        "name": "to",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/v1/audit-report/daily": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "기간 내 감사 로그를 일자/이벤트 기준으로 집계합니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PAYMENT"
                ],
                "summary": "감사 로그 일별 리포트",
                "parameters": [
                    {
                        "type": "string",
                        "description": "조회 시작 시각(RFC3339 또는 YYYY-MM-DD)",
                        "name": "from",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "조회 종료 시각(RFC3339 또는 YYYY-MM-DD)",
                        "name": "to",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/v1/failed_payments": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "실패한 결제 목록을 조회합니다.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PAYMENT"
                ],
                "summary": "실패 결제 목록 조회",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "additionalProperties": true
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/v1/invoice/{order_id}/pdf": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "주문 ID에 대한 인보이스 PDF 파일을 다운로드합니다.",
                "produces": [
                    "application/pdf"
                ],
                "tags": [
                    "PAYMENT"
                ],
                "summary": "인보이스 PDF 다운로드",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "주문 ID",
                        "name": "order_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/v1/payment/invoice": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "주문 정보로 Xendit 인보이스를 생성합니다.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PAYMENT"
                ],
                "summary": "인보이스 생성",
                "parameters": [
                    {
                        "description": "인보이스 생성 요청",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.OrderCreatedEvent"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/debug/mongo/stream": {
            "get": {
                "description": "MongoDB Change Stream 기반의 감사 로그 SSE 스트림입니다.",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "PAYMENT"
                ],
                "summary": "감사 로그 스트림",
                "responses": {
                    "200": {
                        "description": "SSE stream",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/v1/payment/webhook": {
            "post": {
                "description": "Xendit 결제 이벤트 웹훅을 검증하고 처리합니다.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PAYMENT"
                ],
                "summary": "Xendit 웹훅 처리",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Xendit callback token",
                        "name": "x-callback-token",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "웹훅 페이로드",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.XenditWebhookPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "models.OrderCreatedEvent": {
            "type": "object",
            "properties": {
                "order_id": {
                    "type": "integer"
                },
                "payment_method": {
                    "type": "string"
                },
                "shipping_address": {
                    "type": "string"
                },
                "total_amount": {
                    "type": "number"
                },
                "user_id": {
                    "type": "integer"
                }
            }
        },
        "models.XenditWebhookPayload": {
            "type": "object",
            "properties": {
                "amount": {
                    "description": "웹훅에서 오면 총액 검증에 사용",
                    "type": "number"
                },
                "external_id": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        }
    }
}